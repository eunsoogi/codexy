{
  "schema": "codexy.internal.release-publish-contract.v1",
  "name": "codexy",
  "version": "1.2.2",
  "bootstrap": {
    "selectedVersion": "1.2.2",
    "candidateVersion": "1.3.0",
    "publicationWorkflow": ".github/workflows/bootstrap-package.yml"
  },
  "runtime": {
    "selectedTag": "v1.2.2",
    "candidateTagPrefix": "runtime-candidate-",
    "candidateWorkflow": ".github/workflows/runtime-candidate.yml",
    "activationWorkflow": ".github/workflows/runtime-activation.yml",
    "platforms": [
      "darwin-arm64",
      "linux-x86_64"
    ]
  },
  "currentMarketplace": {
    "repository": "https://github.com/eunsoogi/codexy",
    "ref": "main",
    "marketplacePath": ".agents/plugins/marketplace.json",
    "pluginPath": "./plugins/codexy",
    "installCommand": "codex plugin marketplace add eunsoogi/codexy --ref main"
  },
  "package": {
    "workflow": ".github/workflows/plugin-runtime-binaries.yml",
    "archive": "dist/codexy-marketplace-plugin.tar.gz",
    "futureInstallRef": "version-tags",
    "platforms": [
      "darwin-arm64",
      "linux-x86_64"
    ]
  },
  "sourceMarketplace": {
    "path": ".agents/plugins/marketplace.json",
    "mode": "source-checkout-dev"
  }
}
