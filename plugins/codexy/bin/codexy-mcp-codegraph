#!/bin/sh
set -eu

self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
plugin_root=$(CDPATH= cd -- "$self_dir/.." && pwd)
repo_root=$(CDPATH= cd -- "$plugin_root/../.." 2>/dev/null && pwd || true)
export CODEXY_PLUGIN_ROOT="$plugin_root"

if [ -n "$repo_root" ] && [ -f "$repo_root/Cargo.toml" ] && [ -d "$repo_root/src" ]; then
  exec cargo run --locked --quiet --manifest-path "$repo_root/Cargo.toml" --bin codexy-mcp-codegraph -- "$@"
fi

if [ -x "$self_dir/codexy-mcp-codegraph.bin" ]; then
  exec "$self_dir/codexy-mcp-codegraph.bin" "$@"
fi

runtime=$(command -v codexy-mcp-codegraph 2>/dev/null || true)
if [ -n "$runtime" ] && [ "$runtime" != "$0" ] && [ "$runtime" != "$self_dir/codexy-mcp-codegraph" ]; then
  exec "$runtime" "$@"
fi

echo "codexy-mcp-codegraph runtime not found; install the bundled binary or run from the Codexy repository checkout" >&2
exit 127
