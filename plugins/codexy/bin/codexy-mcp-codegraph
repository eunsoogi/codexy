#!/bin/sh
set -eu

self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
plugin_root=$(CDPATH= cd -- "$self_dir/.." && pwd)
repo_root=$(CDPATH= cd -- "$plugin_root/../.." 2>/dev/null && pwd || true)
export CODEXY_PLUGIN_ROOT="$plugin_root"

if [ -n "$repo_root" ] && [ -f "$repo_root/Cargo.toml" ] && [ -d "$repo_root/src" ]; then
  exec cargo run --locked --quiet --manifest-path "$repo_root/Cargo.toml" --bin codexy-mcp-codegraph -- "$@"
fi

platform=${CODEXY_RUNTIME_PLATFORM:-}
if [ -z "$platform" ]; then
  os=$(uname -s 2>/dev/null || echo unknown)
  arch=$(uname -m 2>/dev/null || echo unknown)
  case "$os" in
    Darwin) os=darwin ;;
    Linux) os=linux ;;
    MINGW*|MSYS*|CYGWIN*) os=windows ;;
    *) os=unknown ;;
  esac
  case "$arch" in
    arm64|aarch64) arch=arm64 ;;
    x86_64|amd64) arch=x86_64 ;;
    *) arch=unknown ;;
  esac
  platform="$os-$arch"
fi

runtime_name="codexy-mcp-codegraph-$platform.bin"
if [ -x "$self_dir/$runtime_name" ]; then
  exec "$self_dir/$runtime_name" "$@"
fi

if [ -n "${CODEXY_RUNTIME_DIR:-}" ]; then
  case "$CODEXY_RUNTIME_DIR" in
    /*) ;;
    *)
      echo "codexy-mcp-codegraph runtime dir must be absolute: $CODEXY_RUNTIME_DIR" >&2
      exit 127
      ;;
  esac
  if [ -x "$CODEXY_RUNTIME_DIR/$runtime_name" ]; then
    exec "$CODEXY_RUNTIME_DIR/$runtime_name" "$@"
  fi
fi

echo "codexy-mcp-codegraph runtime not found for $platform; install $runtime_name in the plugin bin directory or set CODEXY_RUNTIME_DIR to an absolute runtime directory" >&2
exit 127
