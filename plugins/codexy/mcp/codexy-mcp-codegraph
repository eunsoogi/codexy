#!/bin/sh
set -eu
case "$0" in */*) script_dir=${0%/*} ;; *) script_dir=. ;; esac
self_dir=$(CDPATH= cd -- "$script_dir" && pwd)
plugin_root=$(CDPATH= cd -- "$self_dir/.." && pwd)
bundled_platforms="darwin-arm64 linux-x86_64"
unset UV_INDEX UV_EXTRA_INDEX_URL UV_FIND_LINKS UV_CONSTRAINT UV_OVERRIDE UV_INSECURE_HOST UV_CONFIG_FILE
export UV_NO_CONFIG=1 UV_DEFAULT_INDEX=https://pypi.org/simple
if [ -n "${CODEXY_UVX_PATH:-}" ]; then
  case "$CODEXY_UVX_PATH" in /*) ;; *) echo "CODEXY_UVX_PATH must be absolute" >&2; exit 127 ;; esac
  [ -x "$CODEXY_UVX_PATH" ] || { echo "CODEXY_UVX_PATH is not executable: $CODEXY_UVX_PATH" >&2; exit 127; }
  uvx_path=$CODEXY_UVX_PATH
else
  if ! command -v uvx >/dev/null 2>&1; then
    echo "codexy-mcp-codegraph requires uvx; install uv from https://docs.astral.sh/uv/" >&2
    exit 127
  fi
  uvx_path=$(command -v uvx)
fi
exec "$uvx_path" --no-config --isolated --default-index https://pypi.org/simple \
  --from "eunsoogi-codexy==1.2.1" codexy-mcp-runtime codegraph \
  --plugin-root "$plugin_root" -- "$@"
