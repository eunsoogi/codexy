#!/bin/sh
set -eu
case "$0" in */*) script_dir=${0%/*} ;; *) script_dir=. ;; esac
self_dir=$(CDPATH= cd -- "$script_dir" && pwd)
plugin_root=$(CDPATH= cd -- "$self_dir/.." && pwd)
bundled_platforms="darwin-arm64 linux-x86_64"
case "$(uname -s)" in Darwin) runtime_os=darwin ;; Linux) runtime_os=linux ;; *) runtime_os=unknown ;; esac
case "$(uname -m)" in arm64|aarch64) runtime_arch=arm64 ;; x86_64|amd64|AMD64) runtime_arch=x86_64 ;; *) runtime_arch=unknown ;; esac
runtime_platform=${CODEXY_RUNTIME_PLATFORM:-$runtime_os-$runtime_arch}
package_sha256=${CODEXY_RUNTIME_PACKAGE_SHA256:-}
case "$package_sha256" in *[A-Z]*) package_sha256=$(printf '%s' "$package_sha256" | tr '[:upper:]' '[:lower:]') ;; esac
json_release() {
  if command -v jq >/dev/null 2>&1; then
    jq -er 'if type == "object" then .version | if type == "string" then . else empty end else empty end' "$1" 2>/dev/null || true
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import json, sys; value = json.load(open(sys.argv[1], encoding="utf-8")); print(value.get("version", "") if isinstance(value, dict) and isinstance(value.get("version"), str) else "")' "$1" 2>/dev/null || true
  fi
}
bundled_runtime="$plugin_root/runtime/codexy-mcp-codegraph-${runtime_platform}.bin"
if [ -n "${CODEXY_RUNTIME_DIR:-}" ]; then
  case "$CODEXY_RUNTIME_DIR" in /*) ;; *) echo "CODEXY_RUNTIME_DIR must be absolute" >&2; exit 127 ;; esac
  runtime="$CODEXY_RUNTIME_DIR/codexy-mcp-codegraph-${runtime_platform}.bin"
  [ -x "$runtime" ] || { echo "codexy-mcp-codegraph runtime not found in CODEXY_RUNTIME_DIR: $runtime" >&2; exit 127; }
  export CODEXY_PLUGIN_ROOT="$plugin_root"
  exec "$runtime" "$@"
fi
if [ -x "$bundled_runtime" ]; then
  export CODEXY_PLUGIN_ROOT="$plugin_root"
  exec "$bundled_runtime" "$@"
fi
if [ -n "${CODEXY_RUNTIME_CACHE_DIR:-}" ]; then
  case "$CODEXY_RUNTIME_CACHE_DIR" in /*) cache_root=$CODEXY_RUNTIME_CACHE_DIR ;; *) cache_root="" ;; esac
elif [ -n "${XDG_CACHE_HOME:-}" ]; then
  case "$XDG_CACHE_HOME" in /*) cache_root="$XDG_CACHE_HOME/codexy/runtime" ;; *) cache_root="" ;; esac
elif [ -n "${HOME:-}" ]; then
  case "$HOME" in /*) cache_root="$HOME/.cache/codexy/runtime" ;; *) cache_root="" ;; esac
else
  cache_root=""
fi
if [ -n "$cache_root" ]; then
  release=$(json_release "$plugin_root/.codex-plugin/plugin.json")
  if [ -n "$release" ]; then
    package_override=0
    if [ -n "${CODEXY_RUNTIME_PACKAGE_PATH:-}" ] || [ "${CODEXY_RUNTIME_PACKAGE_URL+x}" = x ] || [ "${CODEXY_RUNTIME_ARTIFACTS_API_URL+x}" = x ]; then
      package_override=1
      cache_source="package-override
${CODEXY_RUNTIME_PACKAGE_PATH:-}
${CODEXY_RUNTIME_PACKAGE_URL:-}
${CODEXY_RUNTIME_ARTIFACTS_API_URL:-}
${package_sha256}"
    else
      cache_source="package-default
${package_sha256}"
    fi
    cache_hash=""
    if command -v sha256sum >/dev/null 2>&1; then
      cache_hash=$( { printf '%s\000' "codexy.runtime-cache/v2" "${CODEXY_RUNTIME_GIT_REPOSITORY-https://github.com/eunsoogi/codexy}" "${CODEXY_RUNTIME_GIT_REF:-}" "$runtime_platform" "stdio-newline-v1" "$cache_source" "$release"; printf '%s' "codexy-mcp-codegraph"; } | sha256sum | awk '{print $1}')
    elif command -v shasum >/dev/null 2>&1; then
      cache_hash=$( { printf '%s\000' "codexy.runtime-cache/v2" "${CODEXY_RUNTIME_GIT_REPOSITORY-https://github.com/eunsoogi/codexy}" "${CODEXY_RUNTIME_GIT_REF:-}" "$runtime_platform" "stdio-newline-v1" "$cache_source" "$release"; printf '%s' "codexy-mcp-codegraph"; } | shasum -a 256 | awk '{print $1}')
    fi
    cached="$cache_root/v2-$cache_hash/bin/codexy-mcp-codegraph"
    marker="$cache_root/v2-$cache_hash/plugin.json"
    marker_release=$(json_release "$marker")
    if [ -n "$cache_hash" ] && [ -x "$cached" ] && { [ "$package_override" -eq 1 ] || [ "$marker_release" = "$release" ]; }; then
      export CODEXY_PLUGIN_ROOT="$plugin_root"
      exec "$cached" "$@"
    fi
  fi
fi
unset UV_INDEX UV_EXTRA_INDEX_URL UV_FIND_LINKS UV_CONSTRAINT UV_OVERRIDE UV_INSECURE_HOST UV_CONFIG_FILE
export UV_NO_CONFIG=1 UV_DEFAULT_INDEX=https://pypi.org/simple
if [ -n "${CODEXY_UVX_PATH:-}" ]; then
  case "$CODEXY_UVX_PATH" in /*) ;; *) echo "CODEXY_UVX_PATH must be absolute" >&2; exit 127 ;; esac
  [ -x "$CODEXY_UVX_PATH" ] || { echo "CODEXY_UVX_PATH is not executable: $CODEXY_UVX_PATH" >&2; exit 127; }
  uvx_path=$CODEXY_UVX_PATH
else
  if ! command -v uvx >/dev/null 2>&1; then
    echo "codexy-mcp-codegraph requires uvx; install uv from https://docs.astral.sh/uv/" >&2
    exit 127
  fi
  uvx_path=$(command -v uvx)
fi
exec "$uvx_path" --no-config --isolated --default-index https://pypi.org/simple \
  --from "eunsoogi-codexy==1.2.1" codexy-mcp-runtime codegraph \
  --plugin-root "$plugin_root" -- "$@"
