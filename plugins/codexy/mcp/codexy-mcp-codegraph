#!/bin/sh
set -eu

self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
plugin_root=$(CDPATH= cd -- "$self_dir/.." && pwd)
repo_root=$(CDPATH= cd -- "$plugin_root/../.." 2>/dev/null && pwd || true)
export CODEXY_PLUGIN_ROOT="$plugin_root"
bundled_platforms="darwin-arm64 linux-x86_64"

platform=${CODEXY_RUNTIME_PLATFORM:-}
if [ -z "$platform" ]; then
  os=$(uname -s 2>/dev/null || echo unknown)
  arch=$(uname -m 2>/dev/null || echo unknown)
  case "$os" in
    Darwin) os=darwin ;;
    Linux) os=linux ;;
    MINGW*|MSYS*|CYGWIN*) os=windows ;;
    *) os=unknown ;;
  esac
  case "$arch" in
    arm64|aarch64) arch=arm64 ;;
    x86_64|amd64) arch=x86_64 ;;
    *) arch=unknown ;;
  esac
  platform="$os-$arch"
fi

runtime_name="codexy-mcp-codegraph-$platform.bin"
bundled_runtime="$plugin_root/runtime/$runtime_name"
if [ -n "${CODEXY_RUNTIME_DIR:-}" ]; then
  case "$CODEXY_RUNTIME_DIR" in
    /*) ;;
    *)
      echo "codexy-mcp-codegraph runtime dir must be absolute: $CODEXY_RUNTIME_DIR" >&2
      exit 127
      ;;
  esac
  if [ -x "$CODEXY_RUNTIME_DIR/$runtime_name" ]; then
    exec "$CODEXY_RUNTIME_DIR/$runtime_name" "$@"
  fi
  echo "codexy-mcp-codegraph runtime not found for $platform in CODEXY_RUNTIME_DIR: $CODEXY_RUNTIME_DIR/$runtime_name" >&2
  exit 127
fi

if [ -n "$repo_root" ] \
  && [ -f "$repo_root/Cargo.toml" ] \
  && grep -Eq '^name = "codexy-runtime"$' "$repo_root/Cargo.toml" \
  && [ -f "$repo_root/src/bin/codexy-mcp-codegraph.rs" ] \
  && [ -f "$repo_root/plugins/codexy/.codex-plugin/plugin.json" ]; then
  exec cargo run --locked --quiet --manifest-path "$repo_root/Cargo.toml" --bin codexy-mcp-codegraph -- "$@"
fi

case " $bundled_platforms " in
  *" $platform "*)
    if [ -x "$bundled_runtime" ]; then
      exec "$bundled_runtime" "$@"
    fi
    ;;
  *)
    echo "codexy-mcp-codegraph bundled runtime supports: $bundled_platforms; set CODEXY_RUNTIME_DIR to an absolute directory containing codexy-mcp-codegraph-$platform.bin" >&2
    exit 127
    ;;
esac

runtime_git_repository=${CODEXY_RUNTIME_GIT_REPOSITORY:-https://github.com/eunsoogi/codexy}
runtime_git_ref=${CODEXY_RUNTIME_GIT_REF:-main}
if [ -n "${CODEXY_RUNTIME_CACHE_DIR:-}" ]; then
  runtime_cache_root=$CODEXY_RUNTIME_CACHE_DIR
else
  if [ -z "${XDG_CACHE_HOME:-}" ] && [ -z "${HOME:-}" ]; then
    echo "codexy-mcp-codegraph cannot bootstrap runtime without HOME, XDG_CACHE_HOME, or CODEXY_RUNTIME_CACHE_DIR" >&2
    exit 127
  fi
  runtime_cache_root=${XDG_CACHE_HOME:-$HOME/.cache}/codexy/runtime
fi
case "$runtime_cache_root" in
  /*) ;;
  *)
    echo "codexy-mcp-codegraph runtime cache dir must be absolute: $runtime_cache_root" >&2
    exit 127
    ;;
esac
runtime_cache_key=$(printf '%s\n%s\n%s\ncodexy-mcp-codegraph\n' "$runtime_git_repository" "$runtime_git_ref" "$platform" | cksum | awk '{print $1}')
runtime_install_root="$runtime_cache_root/$runtime_cache_key"
installed_runtime="$runtime_install_root/bin/codexy-mcp-codegraph"
runtime_ref_is_pinned=0
case "$runtime_git_ref" in
  *[!0123456789abcdefABCDEF]*|"") ;;
  *)
    if [ "$(printf '%s' "$runtime_git_ref" | wc -c | tr -d ' ')" = 40 ]; then
      runtime_ref_is_pinned=1
    fi
    ;;
esac
if [ "$runtime_ref_is_pinned" = 1 ] && [ -x "$installed_runtime" ]; then
  exec "$installed_runtime" "$@"
fi
if command -v cargo >/dev/null 2>&1; then
  if [ "$runtime_ref_is_pinned" = 1 ]; then
    cargo install --locked --git "$runtime_git_repository" --rev "$runtime_git_ref" --root "$runtime_install_root" --bin codexy-mcp-codegraph
  else
    cargo install --force --locked --git "$runtime_git_repository" --branch "$runtime_git_ref" --root "$runtime_install_root" --bin codexy-mcp-codegraph
  fi
  if [ -x "$installed_runtime" ]; then
    exec "$installed_runtime" "$@"
  fi
fi

if [ -x "$bundled_runtime" ]; then
  exec "$bundled_runtime" "$@"
fi

echo "codexy-mcp-codegraph bundled runtime missing for declared platform $platform: $bundled_runtime" >&2
exit 127
