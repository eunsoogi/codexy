{
  "lsp": {
    "command": [
      "cargo",
      "run",
      "--quiet",
      "--manifest-path",
      "./rust/Cargo.toml",
      "--bin",
      "codexy-mcp-lsp",
      "--"
    ],
    "cwd": "."
  },
  "codegraph": {
    "command": [
      "cargo",
      "run",
      "--quiet",
      "--manifest-path",
      "./rust/Cargo.toml",
      "--bin",
      "codexy-mcp-codegraph",
      "--"
    ],
    "cwd": "."
  },
  "grep_app": {
    "url": "https://mcp.grep.app"
  }
}
