    "kotlin-language-server": {
      "extensions": [
        ".kt",
        ".kts"
      ],
      "priority": 80,
      "command": [
        "kotlin-language-server"
      ]
    },
    "lua-language-server": {
      "extensions": [
        ".lua"
      ],
