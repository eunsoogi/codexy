{
  "lsp": {
    "astro": {
      "extensions": [
        ".astro"
      ],
      "priority": 80,
      "command": [
        "astro-ls"
      ]
    },
    "bash-language-server": {
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh"
      ],
      "priority": 80,
      "command": [
        "bash-language-server",
        "start"
      ]
    },
    "basedpyright": {
      "extensions": [
        ".py",
        ".pyi"
      ],
      "priority": 80,
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ]
    },
    "clangd": {
      "extensions": [
        ".c",
        ".cc",
        ".cpp",
        ".cxx",
        ".h",
        ".hh",
        ".hpp",
        ".hxx"
      ],
      "priority": 80,
      "command": [
        "clangd"
      ]
    },
    "clojure-lsp": {
      "extensions": [
        ".clj",
        ".cljs",
        ".cljc",
        ".edn"
      ],
      "priority": 80,
      "command": [
        "clojure-lsp"
      ]
    },
    "css-language-server": {
      "extensions": [
        ".css",
        ".scss",
        ".less"
      ],
      "priority": 80,
      "command": [
        "vscode-css-language-server",
        "--stdio"
      ]
    },
    "docker-language-server": {
      "extensions": [
        ".dockerfile",
        "Dockerfile"
      ],
      "priority": 80,
      "command": [
        "docker-langserver",
        "--stdio"
      ]
    },
    "emmet-language-server": {
      "extensions": [
        ".html",
        ".htm",
        ".css",
        ".scss",
        ".less",
        ".jsx",
        ".tsx",
        ".vue",
        ".svelte",
        ".astro"
      ],
      "priority": 40,
      "command": [
        "emmet-language-server",
        "--stdio"
      ]
    },
    "elixir-ls": {
      "extensions": [
        ".ex",
        ".exs"
      ],
      "priority": 80,
      "command": [
        "elixir-ls"
      ]
    },
    "fsautocomplete": {
      "extensions": [
        ".fs",
        ".fsi",
        ".fsx"
      ],
      "priority": 80,
      "command": [
        "fsautocomplete"
      ]
    },
    "gleam": {
      "extensions": [
        ".gleam"
      ],
      "priority": 80,
      "command": [
        "gleam",
        "lsp"
      ]
    },
    "gopls": {
      "extensions": [
        ".go"
      ],
      "priority": 80,
      "command": [
        "gopls"
      ]
    },
    "graphql-language-service": {
      "extensions": [
        ".graphql",
        ".gql"
      ],
      "priority": 80,
      "command": [
        "graphql-lsp",
        "server",
        "-m",
        "stream"
      ]
    },
    "haskell-language-server": {
      "extensions": [
        ".hs",
        ".lhs"
      ],
      "priority": 80,
      "command": [
        "haskell-language-server-wrapper",
        "--lsp"
      ]
    },
    "html-language-server": {
      "extensions": [
        ".html",
        ".htm"
      ],
      "priority": 80,
      "command": [
        "vscode-html-language-server",
        "--stdio"
      ]
    },
    "jdtls": {
      "extensions": [
        ".java"
      ],
      "priority": 80,
      "command": [
        "jdtls"
      ]
