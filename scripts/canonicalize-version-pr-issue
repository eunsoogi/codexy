#!/usr/bin/env python3
"""Emit the canonical positive issue number from an authoritative fetch."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

sys.dont_write_bytecode = True

from version_pr_identity import canonicalize_requested_issue


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--requested", required=True)
    parser.add_argument("--issue-json", required=True, type=Path)
    parser.add_argument("--repository", required=True)
    args = parser.parse_args()
    try:
        issue = json.loads(args.issue_json.read_text(encoding="utf-8"))
        identity = canonicalize_requested_issue(args.requested, issue, args.repository)
    except (OSError, json.JSONDecodeError, ValueError) as error:
        print(f"canonicalize-version-pr-issue: {error}", file=sys.stderr)
        return 1
    print(identity.number)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
