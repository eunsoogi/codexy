#!/usr/bin/env python3
"""Validate release-issue scope and render deterministic version PR metadata."""

from __future__ import annotations

import argparse
import json
import re
import sys
import tempfile
from pathlib import Path

VERSION_PATTERN = re.compile(r"[0-9]+\.[0-9]+\.[0-9]+")
STATUS_PREFIX = "status/"
REVIEW_LABEL = "status/review"


def fail(message: str) -> "NoReturn":
    raise ValueError(message)


def read_json(path: Path) -> object:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        fail(f"cannot read JSON from {path}: {error}")


def named_values(items: object, field: str, context: str) -> list[str]:
    if not isinstance(items, list) or not items:
        fail(f"{context} must be a non-empty array")
    values: list[str] = []
    for item in items:
        if not isinstance(item, dict):
            fail(f"{context} entries must be objects")
        value = item.get(field)
        if not isinstance(value, str) or not value.strip():
            fail(f"{context} entries require non-empty {field}")
        values.append(value)
    if len(values) != len(set(values)):
        fail(f"{context} contains duplicates")
    return values


def validate_issue(issue: object, repository_labels: object) -> tuple[int, str, list[str]]:
    if not isinstance(issue, dict):
        fail("issue JSON must be an object")
    number = issue.get("number")
    if not isinstance(number, int) or isinstance(number, bool) or number < 1:
        fail("governing issue number must be a positive integer")
    if issue.get("state") != "OPEN":
        fail(f"governing issue #{number} must be open")
    url = issue.get("url")
    if not isinstance(url, str):
        fail(f"governing issue #{number} requires a canonical issue URL")
    canonical_url = re.compile(
        rf"https://github\.com/(?=[A-Za-z0-9-]{{1,39}}/)"
        rf"[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*/"
        rf"[A-Za-z0-9][A-Za-z0-9._-]{{0,99}}/issues/{number}"
    )
    if canonical_url.fullmatch(url) is None:
        fail(f"governing issue #{number} requires a canonical issue URL")
    milestone = issue.get("milestone")
    if (
        not isinstance(milestone, dict)
        or not isinstance(milestone.get("title"), str)
        or not milestone["title"].strip()
    ):
        fail(f"governing issue #{number} requires a milestone")
    named_values(issue.get("assignees"), "login", f"governing issue #{number} assignees")
    issue_labels = named_values(issue.get("labels"), "name", f"governing issue #{number} labels")
    taxonomy = set(named_values(repository_labels, "name", "repository labels"))
    unknown = sorted(set(issue_labels) - taxonomy)
    if unknown:
        fail(f"governing issue #{number} has unknown labels: {', '.join(unknown)}")
    if REVIEW_LABEL not in taxonomy:
        fail(f"repository labels must contain {REVIEW_LABEL}")
    for prefix in ("priority/", "type/", "area/"):
        if not any(label.startswith(prefix) for label in issue_labels):
            fail(f"governing issue #{number} requires a {prefix} label")
    pr_labels = sorted(
        {label for label in issue_labels if not label.startswith(STATUS_PREFIX)} | {REVIEW_LABEL}
    )
    return number, url, pr_labels


def changed_files(path: Path) -> list[str]:
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except OSError as error:
        fail(f"cannot read changed files from {path}: {error}")
    if not lines:
        fail("changed files must not be empty")
    files: list[str] = []
    for name in lines:
        candidate = Path(name)
        if (
            not name
            or name != name.strip()
            or "`" in name
            or any(ord(character) < 32 for character in name)
            or candidate.is_absolute()
            or ".." in candidate.parts
        ):
            fail(f"unsafe changed file path: {name!r}")
        files.append(name)
    if len(files) != len(set(files)):
        fail("changed files contain duplicates")
    return sorted(files)


def render(
    version: str, number: int, url: str, files: list[str], publication_phase: str
) -> tuple[str, str]:
    title = f"chore(plugin): bump version to {version}\n"
    changed = "\n".join(f"- `{name}`" for name in files)
    readiness_checks = ""
    readiness_evidence = "- Post-creation readiness gates are pending.\n"
    if publication_phase == "proven":
        readiness_checks = """- `plugins/codexy/hooks/codexy-pr-title-check.sh --pr-title <title>`
- `plugins/codexy/hooks/codexy-pr-label-check.sh --pr-state-file <pr-state>`
- `scripts/validate-plugin-config --check-completion-handoff --handoff-file <handoff> --pr-state-file <pr-state>`
- `plugins/codexy/hooks/codexy-merge-message-check.sh --expected-pr <pr-number> --expected-issue <issue-number> --merge-message-file <merge-message>`
"""
        readiness_evidence = "- Post-creation readiness gates passed before final body publication.\n"
    body = f"""## Summary

- Bump Codexy version sources to {version}.
- Keep release metadata synchronized under governing issue #{number}.

## Rationale

- Codexy releases require issue-sized scope and readiness metadata before review.

## Changed Areas

{changed}

## Verification

- `scripts/sync-plugin-version --check`
- `scripts/validate-plugin-config --check`
- `cargo test --locked`
- `git diff --check`
{readiness_checks}

## Evidence

- Governing release issue: {url}
- Full release-candidate validation ran before branch or pull-request mutation.
{readiness_evidence}

## Not Run

- Package publication, tag or release creation, and repository-settings mutation.

## Follow-ups

- None.

Fixes #{number}
"""
    return title, body


def write_outputs(output_dir: Path, title: str, body: str, labels: list[str]) -> None:
    output_dir.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory(dir=output_dir.parent) as temporary:
        stage = Path(temporary)
        (stage / "title.txt").write_text(title, encoding="utf-8")
        (stage / "body.md").write_text(body, encoding="utf-8")
        (stage / "labels.json").write_text(
            json.dumps({"labels": labels}, separators=(",", ":")) + "\n",
            encoding="utf-8",
        )
        output_dir.mkdir(parents=True, exist_ok=True)
        for name in ("title.txt", "body.md", "labels.json"):
            (stage / name).replace(output_dir / name)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument("--version", required=True)
    parser.add_argument("--issue-json", required=True, type=Path)
    parser.add_argument("--repository-labels-json", required=True, type=Path)
    parser.add_argument("--changed-files-file", type=Path)
    parser.add_argument("--output-dir", type=Path)
    parser.add_argument("--validate-only", action="store_true")
    parser.add_argument("--publication-phase", choices=("provisional", "proven"), required=True)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    try:
        if VERSION_PATTERN.fullmatch(args.version) is None:
            fail("version must use MAJOR.MINOR.PATCH form")
        issue = read_json(args.issue_json)
        repository_labels = read_json(args.repository_labels_json)
        number, url, labels = validate_issue(issue, repository_labels)
        if args.validate_only:
            if args.changed_files_file is not None or args.output_dir is not None:
                fail("--validate-only does not accept output arguments")
            return 0
        if args.changed_files_file is None or args.output_dir is None:
            fail("rendering requires --changed-files-file and --output-dir")
        files = changed_files(args.changed_files_file)
        title, body = render(args.version, number, url, files, args.publication_phase)
        write_outputs(args.output_dir, title, body, labels)
        return 0
    except ValueError as error:
        print(f"render-version-pr-metadata: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
