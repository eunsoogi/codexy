#!/usr/bin/env python3
"""Run and enforce the exact complete Rust test workload once."""

from __future__ import annotations

import argparse
import json
import os
import re
import signal
import subprocess
import sys
import time
from pathlib import Path

BUDGET_SECONDS = 180.0
METADATA_TIMEOUT_SECONDS = 30.0
MINIMUM_PASSED_TESTS = 1802
MAXIMUM_INTEGRATION_TARGETS = 8
REQUIRED_JOB_TIMEOUT_MINUTES = 4
WORKLOAD = ("cargo", "test", "--locked", "--all-targets")
RESULT_PATTERN = re.compile(
    r"test result: (?:ok|FAILED)\. (\d+) passed; (\d+) failed; "
    r"(\d+) ignored; \d+ measured; \d+ filtered out"
)
COMPILE_PATTERN = re.compile(r"Finished `test` profile .* in (?:(\d+)m )?([0-9.]+)s")
WORKFLOW_KEY_PATTERN = re.compile(r"^(?P<key>[^:#][^:]*):(?P<value>.*)$")


def integration_target_count(root: Path) -> int:
    try:
        result = subprocess.run(
            ["cargo", "metadata", "--locked", "--no-deps", "--format-version=1"],
            cwd=root,
            capture_output=True,
            text=True,
            check=False,
            timeout=METADATA_TIMEOUT_SECONDS,
        )
    except subprocess.TimeoutExpired:
        sys.stderr.write("cargo metadata timed out\n")
        raise SystemExit(124) from None
    if result.returncode:
        sys.stderr.write(result.stderr)
        raise SystemExit(result.returncode)
    try:
        metadata = json.loads(result.stdout)
        return sum(
            "test" in target.get("kind", [])
            for package in metadata.get("packages", [])
            for target in package.get("targets", [])
        )
    except (json.JSONDecodeError, TypeError):
        sys.stderr.write("cargo metadata returned an invalid target inventory\n")
        raise SystemExit(1) from None
def yaml_mapping_entry(line: str) -> tuple[str, str] | None:
    """Read a plain mapping entry; unsupported workflow syntax fails closed."""
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or stripped.startswith("-"):
        return None
    match = WORKFLOW_KEY_PATTERN.match(stripped)
    if match is None:
        return None
    key = match.group("key").strip()
    value = match.group("value").split("#", 1)[0].strip()
    return key, value
def step_run_command(line: str) -> str | None:
    """Return a direct step `run` scalar, never text inside a block scalar."""
    stripped = line.strip()
    if stripped.startswith("-"):
        stripped = stripped[1:].lstrip()
    entry = yaml_mapping_entry(stripped)
    if entry is None or entry[0] != "run":
        return None
    value = entry[1]
    if value in {"|", "|-", "|+", ">", ">-", ">+"}:
        return None
    return value
def workflow_jobs(source: str) -> dict[str, list[str]]:
    """Parse root `jobs` block mappings and retain each job's own lines."""
    jobs: dict[str, list[str]] = {}
    current_job: str | None = None
    in_jobs = False
    for line in source.splitlines():
        if not line.strip():
            continue
        indentation = len(line) - len(line.lstrip(" "))
        entry = yaml_mapping_entry(line)
        if indentation == 0:
            in_jobs = entry == ("jobs", "")
            current_job = None
            continue
        if not in_jobs:
            continue
        if indentation == 2 and entry is not None and entry[1] == "":
            name = entry[0]
            if name in jobs:
                sys.stderr.write(f"Rust workflow defines job {name!r} more than once\n")
                raise SystemExit(1)
            jobs[name] = []
            current_job = name
            continue
        if current_job is not None:
            jobs[current_job].append(line)
    return jobs
def job_contract(lines: list[str]) -> tuple[list[str], list[str]]:
    """Collect direct job timeout fields and direct `steps[*].run` scalars."""
    timeouts: list[str] = []
    runs: list[str] = []
    in_steps = False
    step_open = False
    for line in lines:
        indentation = len(line) - len(line.lstrip(" "))
        entry = yaml_mapping_entry(line)
        if indentation == 4:
            step_open = False
            in_steps = entry == ("steps", "")
            if entry is not None and entry[0] == "timeout-minutes":
                timeouts.append(entry[1])
            continue
        if not in_steps:
            continue
        if indentation < 6:
            in_steps = False
            step_open = False
            continue
        if indentation == 6 and line.lstrip().startswith("-"):
            step_open = True
            command = step_run_command(line)
            if command is not None:
                runs.append(command)
            continue
        if indentation == 8 and step_open:
            command = step_run_command(line)
            if command is not None:
                runs.append(command)
    return timeouts, runs
def enforce_workflow_contract(workflow: Path) -> None:
    try:
        source = workflow.read_text()
    except OSError as error:
        sys.stderr.write(f"Rust workflow is unreadable: {workflow}: {error}\n")
        raise SystemExit(1) from None
    jobs = workflow_jobs(source)
    if "rust-test" not in jobs:
        sys.stderr.write("Rust workflow must define the rust-test job\n")
        raise SystemExit(1)
    timeouts, rust_runs = job_contract(jobs["rust-test"])
    found = int(timeouts[0]) if len(timeouts) == 1 and timeouts[0].isdigit() else None
    if found != REQUIRED_JOB_TIMEOUT_MINUTES:
        sys.stderr.write(
            f"Rust job timeout must be {REQUIRED_JOB_TIMEOUT_MINUTES} minutes; found {found}\n"
        )
        raise SystemExit(1)
    profiler_runs = [
        command
        for lines in jobs.values()
        for command in job_contract(lines)[1]
        if "scripts/profile-rust-tests" in command
    ]
    if rust_runs.count("scripts/profile-rust-tests") != 1 or len(profiler_runs) != 1:
        sys.stderr.write("Rust workflow must invoke the exact workload gate once\n")
        raise SystemExit(1)
    if "cargo test --locked --all-targets" in source:
        sys.stderr.write("Rust workflow must not run the full workload outside its gate\n")
        raise SystemExit(1)


def nested_build_count(root: Path) -> int:
    helper = root / "tests/support/release_archive.rs"
    try:
        source = helper.read_text()
    except OSError as error:
        sys.stderr.write(f"archive fixture helper is unreadable: {error}\n")
        raise SystemExit(1) from None
    return source.count('Command::new("cargo")')


def run_workload(root: Path) -> tuple[str, float, int]:
    started = time.perf_counter()
    process = subprocess.Popen(
        WORKLOAD,
        cwd=root,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        start_new_session=os.name == "posix",
    )
    try:
        output, _ = process.communicate(timeout=BUDGET_SECONDS)
    except subprocess.TimeoutExpired as error:
        if os.name == "posix":
            os.killpg(process.pid, signal.SIGKILL)
        else:
            process.kill()
        remainder, _ = process.communicate()
        partial = error.output or ""
        if isinstance(partial, bytes):
            partial = partial.decode(errors="replace")
        output = remainder or partial
        sys.stdout.write(output)
        return output, BUDGET_SECONDS, 124
    elapsed = time.perf_counter() - started
    sys.stdout.write(output)
    return output, elapsed, process.returncode


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--root", type=Path, default=Path(__file__).resolve().parent.parent)
    parser.add_argument("--workflow-file", type=Path)
    arguments = parser.parse_args()
    root = arguments.root.resolve()
    workflow = arguments.workflow_file or root / ".github/workflows/rust-test.yml"
    enforce_workflow_contract(workflow)
    targets = integration_target_count(root)
    nested_builds = nested_build_count(root)
    output, elapsed, status = run_workload(root)
    summaries = RESULT_PATTERN.findall(output)
    passed = sum(int(result[0]) for result in summaries)
    failed = sum(int(result[1]) for result in summaries)
    ignored = sum(int(result[2]) for result in summaries)
    compile_matches = COMPILE_PATTERN.findall(output)
    compile_seconds = (
        int(compile_matches[-1][0] or 0) * 60 + float(compile_matches[-1][1])
        if compile_matches
        else 0.0
    )
    execution_seconds = max(0.0, elapsed - compile_seconds)
    target_pass = 0 < targets <= MAXIMUM_INTEGRATION_TARGETS
    tests_pass = passed >= MINIMUM_PASSED_TESTS and failed == 0 and ignored == 0
    nested_pass = nested_builds == 0
    budget_pass = elapsed <= BUDGET_SECONDS
    print(f"command\t{' '.join(WORKLOAD)}")
    print("workload-invocations\t1")
    print(f"integration-targets\t{targets}\t{'PASS' if target_pass else 'FAIL'}")
    print(f"tests\t{passed} passed\t{failed} failed\t{ignored} ignored\t{'PASS' if tests_pass else 'FAIL'}")
    print(f"nested-builds\t{nested_builds}\t{'PASS' if nested_pass else 'FAIL'}")
    print(f"compile-seconds\t{compile_seconds:.3f}")
    print(f"execution-seconds\t{execution_seconds:.3f}")
    print(f"total-seconds\t{elapsed:.3f}")
    print(f"budget-seconds\t{BUDGET_SECONDS:.3f}\t{'PASS' if budget_pass else 'FAIL'}")
    success = status == 0 and target_pass and tests_pass and nested_pass and budget_pass
    print(f"result\t{'PASS' if success else 'FAIL'}")
    return 0 if success else status or 1


if __name__ == "__main__":
    raise SystemExit(main())
