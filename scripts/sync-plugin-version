#!/bin/sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
if [ "${1:-}" = "--check" ]; then
  exec cargo run --locked --quiet --manifest-path "$REPO_ROOT/Cargo.toml" --bin codexy-sync-version -- "$@"
fi
exec cargo run --quiet --manifest-path "$REPO_ROOT/Cargo.toml" --bin codexy-sync-version -- "$@"
